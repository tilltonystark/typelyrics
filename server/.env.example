# Lyritype Backend Environment Variables

# No API key required for lyrics (uses LRCLIB)
PORT=3001

# Spotify Integration (optional — for embedded playback)
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/auth/spotify/callback
